--- !u!114 &3289063402438342079
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1214722322557637591}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 781047f41350fb04d8c6be3406225503, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  boats: {fileID: 8509970069620707817}
  dialogueList:
  - name: 'Aarav : '
    dialogue: "Are you Sagar? They told me you know the way\u2026 my brother\u2019s
      life depends on it."
  - name: 'Sagar : '
    dialogue: "Lady Blue\u2019s Treasure is no ordinary prize. The ocean guards it
      with monsters and secrets. If you wish to save him\u2026 you must prove your
      courage."
  - name: 'Aarav : '
    dialogue: "I\u2019ll do whatever it takes. Just show me the path."
  - name: 'Sagar : '
    dialogue: "Then listen carefully. First\u2026 find the boat waiting along this
      shore. Follow its path into the open sea. Once you set sail, I will guide you
      further. But beware, Aarav\u2014the ocean tests every soul that enters it."
  dialogue_Text: {fileID: 6483320088774234324}
  nextBtn_Text: {fileID: 798954308886601924}
  next_Btn: {fileID: 649667528064488767}
  sagarAnim: {fileID: 3464665012113872652}
